# Triage needs an LLM API key for the live AI features.
# Copy this file to `.env.local` and paste your key below.
#
# The key is read server-side only (in /app/api/* route handlers) and never
# reaches the browser.

# --- Default: Groq (fast, free tier) ---
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# --- Option: Anthropic ---
# In src/lib/ai.ts swap the model line to anthropic("claude-sonnet-4-6"),
# then set the key below. Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# --- Option: OpenAI ---
# npm install @ai-sdk/openai; in src/lib/ai.ts use openai("gpt-4o").
# OPENAI_API_KEY=sk-...
